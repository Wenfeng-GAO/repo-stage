  "product": {
    "name": "openai-agents-python",
    "oneLiner": "The OpenAI Agents SDK is a lightweight yet powerful framework for building multi-agent workflows. It is provider-agnostic, supporting the OpenAI Responses and Chat Completions APIs, as well as 100+ other LLMs.",
    "audiences": [
      "Developers",
      "Frontend teams",
      "AI builders"
    ],
    "problems": [],
    "features": [
      "[`wrapper.context`][agents.run_context.RunContextWrapper.context] for your own mutable app state and dependencies.",
      "[`wrapper.usage`][agents.run_context.RunContextWrapper.usage] for aggregated request and token usage across the current run.",
      "[`wrapper.tool_input`][agents.run_context.RunContextWrapper.tool_input] for structured input when the current run is executing inside [`Agent.as_tool()`][agents.agent.Agent.as_tool].",
      "[`wrapper.approve_tool(...)`][agents.run_context.RunContextWrapper.approve_tool] / [`wrapper.reject_tool(...)`][agents.run_context.RunContextWrapper.reject_tool] when you need to update approval state programmatically."
    ],
    "useCases": [
      "Use from the command line in local development workflows.",
      "Integrate repository capabilities into developer applications."
    ],
    "quickstart": [
      "pip install openai-agents",
      "uv init",
      "uv add openai-agents"
    ],
    "examples": [
      "python -m venv .venv\nsource .venv/bin/activate  # On Windows: .venv\\Scripts\\activate\npip install openai-agents",
      "uv init\nuv add openai-agents",
      "from agents import Agent, ModelSettings, function_tool\n\n@function_tool\ndef get_weather(city: str) -> str:\n    \"\"\"returns weather info for the specified city.\"\"\"\n    return f\"The weather in {city} is sunny\"\n\nagent = Agent(\n    name=\"Haiku agent\",\n    instructions=\"Always respond in haiku form\",\n    model=\"gpt-5-nano\",\n    tools=[get_weather],\n)"
    ],
